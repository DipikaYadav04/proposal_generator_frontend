# Environment Variables Template 
# Copy this file to .env for local development
# For Vercel deployment, add these in Vercel Dashboard -> Settings -> Environment Variables



# Option 1: Use local development server
# REACT_APP_API_BASE_URL=http://127.0.0.1:8000

# Option 2: Use production server  
#REACT_APP_API_BASE_URL=https://proposalgeneratorbackend-production.up.railway.app

# Option 3: Force local development (overrides automatic detection)
#REACT_APP_USE_LOCAL=true

# API Key for backend authentication (required for proposal generation)
# REACT_APP_API_KEY=your-api-key-here

# Default Behavior (when no REACT_APP_API_BASE_URL is set):
# - Development mode (npm start) → http://127.0.0.1:8000
# - Production mode (npm run build) → https://proposalgeneratorbackend-production.up.railway.app
